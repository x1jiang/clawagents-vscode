{
  "name": "clawagents",
  "displayName": "ClawAgents",
  "description": "Coding agent for VS Code — chat, edit, and run tools with OpenAI, Anthropic, Gemini, AWS Bedrock, or local models.",
  "version": "1.0.118",
  "publisher": "clawagents",
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0f766e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/x1jiang/clawagents-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/x1jiang/clawagents-vscode/issues"
  },
  "homepage": "https://github.com/x1jiang/clawagents-vscode#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "keywords": [
    "agent",
    "ai",
    "assistant",
    "openai",
    "gemini",
    "anthropic",
    "clawagents",
    "coding"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "clawagents-activity",
          "title": "ClawAgents",
          "icon": "media/icon.svg",
          "when": "clawagents:useActivityBar"
        }
      ],
      "secondarySidebar": [
        {
          "id": "clawagents",
          "title": "ClawAgents",
          "icon": "media/icon.svg",
          "when": "!clawagents:useActivityBar"
        }
      ]
    },
    "views": {
      "clawagents-activity": [
        {
          "type": "webview",
          "id": "clawagents.sidebarActivity",
          "name": "ClawAgents",
          "visibility": "visible",
          "icon": "media/icon.svg",
          "when": "clawagents:useActivityBar"
        }
      ],
      "clawagents": [
        {
          "type": "webview",
          "id": "clawagents.sidebar",
          "name": "ClawAgents",
          "visibility": "visible",
          "icon": "media/icon.svg",
          "when": "!clawagents:useActivityBar"
        }
      ]
    },
    "commands": [
      {
        "command": "clawagents.openChat",
        "title": "ClawAgents: Open Chat",
        "icon": {
          "light": "media/icon-light.svg",
          "dark": "media/icon.svg"
        }
      },
      {
        "command": "clawagents.toggleChat",
        "title": "ClawAgents: Toggle Sidebar",
        "icon": "$(layout-sidebar-right)"
      },
      {
        "command": "clawagents.newChat",
        "title": "ClawAgents: New Chat",
        "icon": "$(add)"
      },
      {
        "command": "clawagents.addSelectionToChat",
        "title": "ClawAgents: Add Selection to Chat"
      },
      {
        "command": "clawagents.addFileToChat",
        "title": "ClawAgents: Add Current File to Chat"
      },
      {
        "command": "clawagents.explainSelection",
        "title": "ClawAgents: Explain Selection"
      },
      {
        "command": "clawagents.fixProblems",
        "title": "ClawAgents: Fix Workspace Problems"
      },
      {
        "command": "clawagents.cancel",
        "title": "ClawAgents: Cancel Task",
        "icon": "$(debug-stop)"
      },
      {
        "command": "clawagents.restartSidecar",
        "title": "ClawAgents: Restart Sidecar",
        "icon": "$(refresh)"
      },
      {
        "command": "clawagents.selectWorkspaceRoot",
        "title": "ClawAgents: Select Workspace Root"
      },
      {
        "command": "clawagents.setApiKey",
        "title": "ClawAgents: Set API Key (OpenAI / Anthropic / Gemini / Bedrock / Tavily)"
      },
      {
        "command": "clawagents.clearApiKey",
        "title": "ClawAgents: Clear API Key…"
      },
      {
        "command": "clawagents.installPythonDeps",
        "title": "ClawAgents: Install/Upgrade Python Dependencies"
      },
      {
        "command": "clawagents.doctorPython",
        "title": "ClawAgents: Doctor (Python versions)"
      },
      {
        "command": "clawagents.ensureCompanions",
        "title": "ClawAgents: Ensure Companions (context-mode / rtk)"
      }
    ],
    "keybindings": [
      {
        "command": "clawagents.openChat",
        "key": "ctrl+shift+'",
        "mac": "cmd+shift+'"
      },
      {
        "command": "clawagents.toggleChat",
        "key": "ctrl+shift+;",
        "mac": "cmd+shift+;"
      },
      {
        "command": "clawagents.addSelectionToChat",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l",
        "when": "editorHasSelection"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "clawagents.newChat",
          "when": "view == clawagents.sidebar || view == clawagents.sidebarActivity",
          "group": "navigation@1"
        },
        {
          "command": "clawagents.cancel",
          "when": "view == clawagents.sidebar || view == clawagents.sidebarActivity",
          "group": "navigation@2"
        },
        {
          "command": "clawagents.restartSidecar",
          "when": "view == clawagents.sidebar || view == clawagents.sidebarActivity",
          "group": "navigation@3"
        }
      ],
      "editor/title": [
        {
          "command": "clawagents.openChat",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "clawagents.addSelectionToChat",
          "when": "editorHasSelection",
          "group": "clawagents@1"
        },
        {
          "command": "clawagents.explainSelection",
          "when": "editorHasSelection",
          "group": "clawagents@2"
        },
        {
          "command": "clawagents.addFileToChat",
          "group": "clawagents@3"
        }
      ]
    },
    "configuration": {
      "title": "ClawAgents",
      "properties": {
        "clawagents.revealOnStartup": {
          "type": "boolean",
          "default": false,
          "description": "On startup, focus the ClawAgents sidebar view."
        },
        "clawagents.pythonPath": {
          "type": "string",
          "default": "python3",
          "scope": "machine-overridable",
          "description": "Base Python used to create the managed sidecar environment, or the exact sidecar interpreter when Python Runtime is Custom. Workspace absolute paths are ignored for security."
        },
        "clawagents.pythonRuntime": {
          "type": "string",
          "enum": [
            "managed",
            "custom"
          ],
          "default": "managed",
          "scope": "machine-overridable",
          "description": "Managed isolates sidecar packages in VS Code global storage. Custom uses clawagents.pythonPath directly."
        },
        "clawagents.model": {
          "type": "string",
          "default": "",
          "description": "Optional model override (e.g. gpt-4o, gemini-2.5-flash, us.anthropic.claude-sonnet-4-5-20250929-v1:0). Empty uses clawagents defaults."
        },
        "clawagents.provider": {
          "type": "string",
          "enum": [
            "openai",
            "anthropic",
            "gemini",
            "bedrock",
            "auto"
          ],
          "default": "auto",
          "description": "Which provider credential slot (SecretStorage) to prefer when starting the sidecar."
        },
        "clawagents.defaultMode": {
          "type": "string",
          "enum": [
            "ask",
            "read_only",
            "auto",
            "full_access"
          ],
          "default": "auto",
          "description": "Default permission mode for agent turns."
        },
        "clawagents.includeContextByDefault": {
          "type": "boolean",
          "default": false,
          "description": "When true, the Context checkbox starts checked and attaches active-editor snippets to each send (never shown in chat history; .env and other secret files are omitted)."
        },
        "clawagents.contextMode": {
          "type": "boolean",
          "default": true,
          "description": "Enable Context Mode (github.com/mksglu/context-mode): token-efficient ctx_* tools — sandboxed code execution and indexed search. Requires context-mode >=1.0.169; auto-installed when clawagents.ensureCompanions is true. The sidebar Settings checkbox overrides this per workspace."
        },
        "clawagents.ensureCompanions": {
          "type": "boolean",
          "default": false,
          "description": "When true, sidecar start may offer to install/upgrade companion CLIs (npm context-mode, Homebrew rtk) after confirmation. Default is probe-only; use ClawAgents: Ensure Companions for an explicit install."
        },
        "clawagents.syncPathPythons": {
          "type": "boolean",
          "default": false,
          "description": "When true, activation may offer (with confirmation) to upgrade clawagents on other PATH interpreters below this extension's floor. Default off — only clawagents.pythonPath is managed unless you opt in or run Install/Doctor."
        },
        "clawagents.alpacaDeployPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to a local folder whose .env supplies EMAIL_* SMTP credentials for in-extension bug reports. Also set ALPACA_DEPLOY_ROOT or EMAIL_PASSWORD in the environment."
        },
        "clawagents.bugReportEmailSender": {
          "type": "string",
          "default": "",
          "description": "Optional SMTP sender (EMAIL_SENDER) for bug reports when not set in the environment."
        },
        "clawagents.bugReportSmtpServer": {
          "type": "string",
          "default": "",
          "description": "Optional SMTP server hostname (EMAIL_SMTP_SERVER) for bug reports."
        },
        "clawagents.bugReportSmtpPort": {
          "type": "string",
          "default": "",
          "description": "Optional SMTP port (EMAIL_SMTP_PORT) for bug reports."
        },
        "clawagents.bugReportEmailTo": {
          "type": "string",
          "default": "",
          "description": "Optional bug-report mailto recipient (CLAWAGENTS_BUG_REPORT_EMAIL). When empty, the fallback opens a GitHub issue draft instead of an empty mailto."
        },
        "clawagents.autoOpenChangedFiles": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open the latest file the agent writes or edits (debounced; failures stay in the Sidecar output log, not chat)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run typecheck && npm run build:webview && npm run build:ext",
    "build:ext": "node esbuild.mjs",
    "build:webview": "npm run build --prefix webview",
    "typecheck": "tsc --noEmit && tsc --noEmit -p webview",
    "test": "node --test test/*.test.cjs",
    "watch": "node esbuild.mjs --watch",
    "install:all": "npm install && npm install --prefix webview",
    "package": "npx --yes @vscode/vsce package",
    "publish": "npx --yes @vscode/vsce publish",
    "publish:ovsx": "npx --yes ovsx publish"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25.12",
    "typescript": "^5.5.0"
  }
}
